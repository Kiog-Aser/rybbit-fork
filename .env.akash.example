# Akash lean deployment — copy to .env and fill secrets before deploy
DOMAIN_NAME=analytics.yourdomain.com
BASE_URL=https://analytics.yourdomain.com

BETTER_AUTH_SECRET=generate-a-long-random-string
DISABLE_SIGNUP=true
DISABLE_TELEMETRY=true
USE_WEBSERVER=false

CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change-me
POSTGRES_DB=analytics
POSTGRES_USER=frog
POSTGRES_PASSWORD=change-me
REDIS_PASSWORD=change-me

# Lean mode (set automatically by docker-compose.akash.yml)
AKASH_LEAN_MODE=true
LITE_DASHBOARD=true
CLUSTER_WORKERS=1
DEPLOYMENT=akash
REVENUE_ATTRIBUTION=true

# Optional: encrypt stored Stripe restricted keys (defaults to BETTER_AUTH_SECRET)
# REVENUE_ENCRYPTION_KEY=

# Stripe revenue webhooks — set after connecting Stripe in Site Settings
# STRIPE_REVENUE_WEBHOOK_SECRET=

MAPBOX_TOKEN=